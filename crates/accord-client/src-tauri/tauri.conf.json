{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Accord",
  "version": "0.1.0",
  "identifier": "com.accord.desktop",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Accord",
        "width": 1100,
        "height": 720,
        "minWidth": 760,
        "minHeight": 480,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
